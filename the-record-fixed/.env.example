# ─────────────────────────────────────────────────────────────────
# The Record — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────

# ── Shelby Protocol ──────────────────────────────────────────────
# RPC endpoint for your chosen network
# testnet:   https://api.testnet.shelby.xyz/shelby
# shelbynet: https://api.shelbynet.shelby.xyz/shelby
SHELBY_RPC_ENDPOINT=https://api.testnet.shelby.xyz/shelby

# Network name (testnet | shelbynet | local)
SHELBY_NETWORK=testnet

# Optional API key — get from https://docs.shelby.xyz/sdks/typescript/acquire-api-keys
# Strongly recommended to avoid rate limits
SHELBY_API_KEY=

# ── Aptos Account ────────────────────────────────────────────────
# Your Aptos private key (ed25519 format from shelby init)
# Run: shelby account list  — to get your address
# Run: shelby init          — to get your private key
APTOS_PRIVATE_KEY=ed25519-priv-0x...
APTOS_ACCOUNT_ADDRESS=0x...
APTOS_FULLNODE_URL=https://api.testnet.aptoslabs.com/v1

# ── Public (safe to expose to browser) ───────────────────────────
NEXT_PUBLIC_SHELBY_NETWORK=testnet
NEXT_PUBLIC_APTOS_EXPLORER_BASE=https://explorer.aptoslabs.com/txn
NEXT_PUBLIC_SHELBY_EXPLORER_BASE=https://explorer.shelby.xyz/testnet/account

# ─────────────────────────────────────────────────────────────────
# HOW TO GET STARTED:
#
# 1. Install Shelby CLI:
#    npm i -g @shelby-protocol/cli
#
# 2. Initialise:
#    shelby init
#    (This creates ~/.shelby/config.yaml with your account + key)
#
# 3. Fund your account with both APT and ShelbyUSD:
#    shelby faucet --network testnet
#
# 4. Copy your private key + address from ~/.shelby/config.yaml
#    into this file.
#
# 5. Run: npm run dev
# ─────────────────────────────────────────────────────────────────
