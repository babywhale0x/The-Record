# Steps: sign in → create new API key → select "testnet" network
SHELBY_API_KEY=aptoslabs_xxxxxxxxxxxxxxxxxxxx

# Optional: CDN URL for reads (see CDN_SETUP.md for Bunny CDN instructions)
# If set, blob reads go through CDN; writes still go direct to Shelby
# SHELBY_CDN_URL=https://your-zone.b-cdn.net

# ── Aptos Account ────────────────────────────────────────────────
# Get these by running: npx @shelby-protocol/cli init
# Or install CLI globally: npm i -g @shelby-protocol/cli
APTOS_PRIVATE_KEY=ed25519-priv-0x...
APTOS_ACCOUNT_ADDRESS=0x...
APTOS_FULLNODE_URL=https://api.shelbynet.shelby.xyz/v1

# ── Supabase ─────────────────────────────────────────────────────
# Create project at https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Cron job secret ───────────────────────────────────────────────
# Vercel sets this automatically for cron routes.
# For local dev, set any string and use it in Authorization: Bearer <secret>
CRON_SECRET=replace-with-random-secret

# ── Wallet UX (browser) ──────────────────────────────────────────
# Aptos Connect (Petra Web / Google sign-in)
# Must match your configured Aptos Connect dapp id + allowed domains.
# Create/configure at: https://aptosconnect.app
NEXT_PUBLIC_APTOS_CONNECT_DAPP_ID=your-aptos-connect-dapp-id
NEXT_PUBLIC_APTOS_NETWORK=testnet

# ── Public env vars (safe to expose to browser) ───────────────────
NEXT_PUBLIC_SHELBY_NETWORK=shelbynet
NEXT_PUBLIC_APTOS_EXPLORER_BASE=https://explorer.aptoslabs.com/txn
NEXT_PUBLIC_SHELBY_EXPLORER_BASE=https://explorer.shelby.xyz/testnet/account

# ══════════════════════════════════════════════════════════════════
# QUICK START (5 steps)
#
# 1. Install official Shelby CLI:
#    npm i -g @shelby-protocol/cli
#
# 2. Create a Shelby account:
#    shelby init
#    → copies config to ~/.shelby/config.yaml
#    → paste APTOS_PRIVATE_KEY and APTOS_ACCOUNT_ADDRESS from there
#
# 3. Get testnet tokens (both APT + ShelbyUSD needed):
#    APT faucet:       https://docs.shelby.xyz/apis/faucet/aptos
#    ShelbyUSD faucet: https://docs.shelby.xyz/apis/faucet/shelbyusd
#
# 4. Get a Geomi API key (avoid rate limits):
#    https://geomi.dev → sign in → create key → select testnet
#    → paste as SHELBY_API_KEY above
#
# 5. Set up Supabase: